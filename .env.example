# Application Settings
APP_NAME=Shop Assistant Chat
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# Server Settings
HOST=0.0.0.0
PORT=8000
API_PREFIX=/api

# CORS Settings
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:8080", "http://localhost"]
ALLOWED_METHODS=["GET", "POST", "PUT", "DELETE", "OPTIONS"]
ALLOWED_HEADERS=["*"]

# Redis Settings (外部Redis服务器)
REDIS_URL=redis://:acctrue666888666@183.222.230.18:6379/0

# AI Model Settings
BASE_URL=http://183.222.230.18:8000/v1
API_KEY=
MODEL_ID=Qwen/Qwen3.5-35B-A3B
MODEL_TEMPERATURE=0.7
MODEL_MAX_TOKENS=2048
MODEL_TIMEOUT=30

# OpenAI Settings (可选，如果使用OpenAI)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_BASE_URL=https://api.openai.com/v1

# Logging Settings
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_PATH=logs/app.log
LOG_MAX_SIZE=10MB
LOG_BACKUP_COUNT=5

# External Services
BING_SEARCH_API_KEY=your_bing_search_api_key
BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search

# Docker Settings
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_BUILDKIT=1
